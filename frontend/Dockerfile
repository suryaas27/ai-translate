FROM node:20-alpine AS builder
WORKDIR /app

# Build-time args for white-labeling and per-feature API URLs
ARG VITE_CUSTOMER=doqfy
ARG VITE_TRANSLATION_URL
ARG VITE_TRANSLITERATION_URL
ARG VITE_COMPARISON_URL
ARG VITE_SUMMARY_URL
ARG VITE_INTERACT_URL
ARG VITE_EXTRACT_URL

# Expose as ENV so Vite picks them up during npm run build
ENV VITE_CUSTOMER=$VITE_CUSTOMER
ENV VITE_TRANSLATION_URL=$VITE_TRANSLATION_URL
ENV VITE_TRANSLITERATION_URL=$VITE_TRANSLITERATION_URL
ENV VITE_COMPARISON_URL=$VITE_COMPARISON_URL
ENV VITE_SUMMARY_URL=$VITE_SUMMARY_URL
ENV VITE_INTERACT_URL=$VITE_INTERACT_URL
ENV VITE_EXTRACT_URL=$VITE_EXTRACT_URL

COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
